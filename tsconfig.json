{
  "include": [
    "src/**/*"
  ],
"exclude": [
  "node_modules",
  "build"
],
  "compilerOptions": {
    "jsx": "react",
    "target": "ES6",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "build",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "incremental": true,
    "tsBuildInfoFile": "./build/.tsbuildinfo",
    "sourceMap": false

  }
}
